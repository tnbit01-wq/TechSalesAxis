# AWS DATABASE CONNECTION
# -------------------------
# Replace your current SUPABASE variables with these when you move to AWS RDS/Aurora.

# Use this for SQLAlchemy/psycopg2
DATABASE_URL="postgresql://postgres:YOUR_PASSWORD@your-rds-endpoint.aws.com:5432/talentflow"

# AWS S3 Storage
AWS_ACCESS_KEY_ID="YOUR_AWS_ACCESS_KEY_ID"
AWS_SECRET_ACCESS_KEY="YOUR_AWS_SECRET_ACCESS_KEY"
AWS_REGION="ap-southeast-2"
S3_BUCKET_NAME="talentflow-files"

# Optional: If you still use Supabase for ONLY Auth (the easiest path)
# SUPABASE_URL="https://your-project.supabase.co"
# SUPABASE_ANON_KEY="your-anon-key"
